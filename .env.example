# Optional regional workspace used by common runtime helpers, CLI, and dashboard.
# Explicit --workspace / Python arguments still win over this value.
MGB_OPS_WORKSPACE=scratch/rs_hydro

# Optional remote workspace used when running the MGB executable.
MGB_OPS_REMOTE_WORKSPACE=C:/mgb-hora

# Required only for INMET/BNDMET ingestion through common runtime helpers or CLI.
INMET_API_KEY=SUA_CHAVE_AQUI
